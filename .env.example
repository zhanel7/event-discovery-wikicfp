# Event Discovery Service — environment variables
# Copy to .env and set values (do not commit .env)

# Required in production
SECRET_KEY=your-secret-key-min-32-chars

# Database (defaults work with docker-compose)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/eventdb
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/eventdb

# App
DEBUG=false
ENVIRONMENT=production
API_V1_PREFIX=/api/v1

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated origins)
# CORS_ORIGINS=http://localhost:3000,https://yourfrontend.com
